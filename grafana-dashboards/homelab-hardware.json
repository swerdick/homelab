{
  "annotations": {
    "list": []
  },
  "description": "Per-disk SMART status, temperatures, wear, and host hwmon (CPU + ACPI thermal zones). Targets physical hosts only — currently earendil. v1 — expect tweaks.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "smartctl_device_smart_status: 1 = PASS, 0 = FAIL. One tile per disk.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "red",
                  "text": "FAIL"
                },
                "1": {
                  "color": "green",
                  "text": "PASS"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device_smart_status{instance=\"$instance\"} * on (device, instance) group_left(model_name) smartctl_device{instance=\"$instance\"}",
          "instant": true,
          "legendFormat": "{{device}} ({{model_name}})",
          "refId": "A"
        }
      ],
      "title": "SMART status — overall",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "smartctl_device_temperature{temperature_type=\"current\"} per disk.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 40
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device_temperature{instance=\"$instance\",temperature_type=\"current\"} * on (device, instance) group_left(model_name) smartctl_device{instance=\"$instance\"}",
          "instant": true,
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "title": "Disk temperatures — current",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 50
              },
              {
                "color": "red",
                "value": 60
              }
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max",
            "mean"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device_temperature{instance=\"$instance\",temperature_type=\"current\"} * on (device, instance) group_left(model_name) smartctl_device{instance=\"$instance\"}",
          "legendFormat": "{{device}} ({{model_name}})",
          "refId": "A"
        }
      ],
      "title": "Disk temperatures — over time",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "platform_coretemp_0: temp1 = package, temp2-5 = cores 0-3.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 1,
            "showPoints": "never",
            "thresholdsStyle": {
              "mode": "line"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 75
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "id": 4,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_hwmon_temp_celsius{instance=\"$instance\",chip=\"platform_coretemp_0\"}",
          "legendFormat": "{{sensor}}",
          "refId": "A"
        }
      ],
      "title": "CPU temperatures (coretemp) — package + per-core",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "thermal_zone0 (acpitz) = chassis/board area; thermal_zone2 (pch_skylake) = chipset PCH. zone1 (second acpitz) and zone3 (x86_pkg_temp, duplicate of CPU package) aren't exposed by node_exporter's hwmon collector.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 1,
            "showPoints": "never"
          },
          "unit": "celsius"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "last",
            "max"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "node_hwmon_temp_celsius{instance=\"$instance\",chip=~\"thermal_thermal_zone.*\"}",
          "legendFormat": "{{chip}} {{sensor}}",
          "refId": "A"
        }
      ],
      "title": "ACPI thermal zones",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Active running time per disk. Formatted as duration with multi-unit precision (year/month/week/day).",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Power-on time"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dtdurations"
              },
              {
                "id": "decimals",
                "value": 3
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 20
      },
      "id": 6,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device_power_on_seconds{instance=\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Power-on time",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "cluster": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "Value": 1,
              "device": 0
            },
            "renameByName": {
              "Value": "Power-on time",
              "device": "Device"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Reallocated_Sector_Ct raw value. Any non-zero on a rotational drive is worth flagging; growth over time = drive failing.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 20
      },
      "id": 7,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device_attribute{instance=\"$instance\",attribute_name=\"Reallocated_Sector_Ct\",attribute_value_type=\"raw\"}",
          "instant": true,
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "title": "Reallocated sectors",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Current_Pending_Sector raw value. Any non-zero = sectors waiting to be remapped on next write; replace soon.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 20
      },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device_attribute{instance=\"$instance\",attribute_name=\"Current_Pending_Sector\",attribute_value_type=\"raw\"}",
          "instant": true,
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "title": "Current pending sectors",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Wear_Leveling_Count normalized value. Starts at 100 on a fresh SSD; vendor-defined floor is typically 0 (drive declares end-of-life, may go read-only).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 20
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "id": 9,
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device_attribute{instance=\"$instance\",attribute_name=\"Wear_Leveling_Count\",attribute_value_type=\"value\"}",
          "instant": true,
          "legendFormat": "{{device}}",
          "refId": "A"
        }
      ],
      "title": "Samsung 850 EVO — wear leveling (value, lower = more worn)",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "LBAs are 512-byte sectors on these drives. Useful as a cumulative-write proxy on the SSD.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "blue",
            "mode": "fixed"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*written.*"
            },
            "properties": [
              {
                "id": "unit",
                "value": "bytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byRegexp",
              "options": ".*cycles.*"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "color",
                "value": {
                  "fixedColor": "purple",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "id": 10,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device_attribute{instance=\"$instance\",attribute_name=\"Total_LBAs_Written\",attribute_value_type=\"raw\"} * 512",
          "instant": true,
          "legendFormat": "{{device}} written",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device_power_cycle_count{instance=\"$instance\"}",
          "instant": true,
          "legendFormat": "{{device}} cycles",
          "refId": "B"
        }
      ],
      "title": "Total LBAs written / power-cycle count",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Device → model lookup, pulled from the smartctl_device info metric.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "id": 11,
      "options": {
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "smartctl_device{instance=\"$instance\"}",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Disk inventory",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "ata_additional_product_id": true,
              "ata_version": true,
              "cluster": true,
              "form_factor": true,
              "instance": true,
              "interface": true,
              "job": true,
              "protocol": true,
              "sata_version": true,
              "scsi_product": true,
              "scsi_revision": true,
              "scsi_vendor": true,
              "scsi_version": true
            },
            "indexByName": {
              "device": 0,
              "firmware_version": 4,
              "model_family": 1,
              "model_name": 2,
              "serial_number": 3
            },
            "renameByName": {
              "device": "Device",
              "firmware_version": "Firmware",
              "model_family": "Family",
              "model_name": "Model",
              "serial_number": "Serial"
            }
          }
        }
      ],
      "type": "table"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": [
    "homelab",
    "hardware",
    "smart"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "earendil",
          "value": "earendil"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "includeAll": false,
        "label": "Host",
        "multi": false,
        "name": "instance",
        "query": {
          "query": "label_values(smartctl_device, instance)",
          "refId": "instance"
        },
        "refresh": 1,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Homelab — Hardware",
  "uid": "homelab-hardware"
}
