      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{instance=\"$host\",job=\"integrations/unix\",mode!=\"idle\"}[$__rate_interval])) * 100",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "title": "CPU usage — $host",
      "type": "timeseries"
    },
